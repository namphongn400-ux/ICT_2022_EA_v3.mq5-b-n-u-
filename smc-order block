//@version=6
indicator("Smart Money Concepts - Order Blocks [LuxAlgo]", overlay = true, max_boxes_count = 500, max_lines_count = 500)

// --- Group: Core Settings ---
int length = input.int(5, "Swing Length", group = "Structure")
color strongObBullColor = input.color(color.new(#089981, 70), "Strong Bull OB", group = "Style")
color strongObBearColor = input.color(color.new(#f23645, 70), "Strong Bear OB", group = "Style")
color weakObBullColor   = input.color(color.new(#089981, 90), "Weak Bull OB", group = "Style")
color weakObBearColor   = input.color(color.new(#f23645, 90), "Weak Bear OB", group = "Style")

// --- Swing Points ---
float ph = ta.pivothigh(high, length, length)
float pl = ta.pivotlow(low, length, length)

var float lastPh = na
var float lastPl = na
var int lastPhIndex = na
var int lastPlIndex = na

if not na(ph)
    lastPh := ph
    lastPhIndex := bar_index[length]
if not na(pl)
    lastPl := pl
    lastPlIndex := bar_index[length]

// --- Trend and Structure ---
var int trend = 0 // 1 for bull, -1 for bear
var bool isChoch = false
var bool isBos = false

float lastHigh = na
float lastLow = na

// Simplified structure logic
if close > lastPh and trend <= 0
    trend := 1
    isChoch := trend == -1 ? true : false
    isBos := trend == 0 ? true : false
else if close < lastPl and trend >= 0
    trend := -1
    isChoch := trend == 1 ? true : false
    isBos := trend == 0 ? true : false
else
    isChoch := false
    isBos := false

if close > lastPh and trend == 1
    isBos := true
if close < lastPl and trend == -1
    isBos := true

// --- Premium / Discount ---
var float waveHigh = na
var float waveLow = na

if trend == 1
    waveHigh := high
    waveLow := lastPl
else if trend == -1
    waveLow := low
    waveHigh := lastPh

float eqLevel = waveLow + (waveHigh - waveLow) * 0.5
bool inDiscount = close < eqLevel
bool inPremium = close > eqLevel

// --- Order Blocks ---
type OrderBlock
    float top
    float bottom
    int left
    int right
    bool isBull
    bool isStrong
    bool mitigated
    box obBox
    float volumeVal

var array<OrderBlock> obList = array.new<OrderBlock>()

// Function to find last opposite candle
findLastOppositeCandle(isBull, startIndex) =>
    float top = na
    float bottom = na
    float vol = na
    int idx = bar_index
    for i = 1 to 20
        if isBull and close[i] < open[i]
            top := high[i]
            bottom := low[i]
            vol := volume[i]
            idx := bar_index[i]
            break
        else if not isBull and close[i] > open[i]
            top := high[i]
            bottom := low[i]
            vol := volume[i]
            idx := bar_index[i]
            break
    [top, bottom, idx, vol]

if isChoch or isBos
    bool isBull = trend == 1
    [obTop, obBottom, obIdx, obVol] = findLastOppositeCandle(isBull, bar_index)
    
    // Filter Premium/Discount
    bool validZone = isBull ? (obTop < eqLevel) : (obBottom > eqLevel)
    
    if not na(obTop) and validZone
        color boxColor = na
        if isBull
            boxColor := isChoch ? strongObBullColor : weakObBullColor
        else
            boxColor := isChoch ? strongObBearColor : weakObBearColor
            
        box newBox = box.new(obIdx, obTop, bar_index, obBottom, border_color = color.new(boxColor, 0), bgcolor = boxColor)
        obList.push(OrderBlock.new(obTop, obBottom, obIdx, bar_index, isBull, isChoch, false, newBox, obVol))

// Mitigation Logic
if array.size(obList) > 0
    for i = array.size(obList) - 1 to 0
        OrderBlock ob = array.get(obList, i)
        if not ob.mitigated
            ob.obBox.set_right(bar_index)
            if ob.isBull and low < ob.top
                ob.mitigated := true
                ob.obBox.set_bgcolor(color.new(strongObBullColor, 95))
            else if not ob.isBull and high > ob.bottom
                ob.mitigated := true
                ob.obBox.set_bgcolor(color.new(strongObBearColor, 95))

// --- Dashboard ---
// MTF Trend Analysis
f_get_trend(tf) =>
    request.security(syminfo.tickerid, tf, close > ta.ema(close, 50) ? 1 : -1)

t_m5  = f_get_trend("5")
t_m15 = f_get_trend("15")
t_h1  = f_get_trend("60")
t_h4  = f_get_trend("240")

var table dash = table.new(position.top_left, 2, 5, border_width = 1)
if barstate.islast
    table.cell(dash, 0, 0, "Timeframe", text_color = color.white, bgcolor = color.gray)
    table.cell(dash, 1, 0, "Trend", text_color = color.white, bgcolor = color.gray)
    
    table.cell(dash, 0, 1, "M5", text_color = color.white, bgcolor = color.black)
    table.cell(dash, 1, 1, t_m5 > 0 ? "BULL" : "BEAR", text_color = color.white, bgcolor = t_m5 > 0 ? color.green : color.red)
    
    table.cell(dash, 0, 2, "M15", text_color = color.white, bgcolor = color.black)
    table.cell(dash, 1, 2, t_m15 > 0 ? "BULL" : "BEAR", text_color = color.white, bgcolor = t_m15 > 0 ? color.green : color.red)
    
    table.cell(dash, 0, 3, "H1", text_color = color.white, bgcolor = color.black)
    table.cell(dash, 1, 3, t_h1 > 0 ? "BULL" : "BEAR", text_color = color.white, bgcolor = t_h1 > 0 ? color.green : color.red)
    
    table.cell(dash, 0, 4, "H4", text_color = color.white, bgcolor = color.black)
    table.cell(dash, 1, 4, t_h4 > 0 ? "BULL" : "BEAR", text_color = color.white, bgcolor = t_h4 > 0 ? color.green : color.red)
